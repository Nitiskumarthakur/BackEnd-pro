<% layout("/layouts/boilerplate") %>
    <div class="row mt-3">
        <div class="col-md-4  offset-md-3 mobile-width">
            <div class="welcome-section">
                <h3>Welcome Back! 👋</h3>
                <p>Login to your account</p>
            </div>
            <form action="login" method="POST">
                <div class="input-group mb-3 ">
                    <span class="input-group-text">@</span>
                    <div class="form-floating logInp">
                        <input type="text" name="username" class="form-control" id="username" placeholder="Username"  required>
                        <label for="username">Username</label>
                    </div>
                </div>
                 <div class="input-group form-floating">
                    <input type="password" id="password" name="password" class="form-control" placeholder="Password">
                    <label for="password">Password</label>
                    <button class="btn btn-outline-secondary" type="button" id="toggleBtn">
                        <i class="fa fa-eye" id="eyeIcon"></i>
                    </button>
                </div>
                <div class="d-grid gap-2">
                    <button class="btn loginBtn  mt-3">Sign Up</button>
               </div>
               <div class="nothaveAccount">
                   <p>Don't have an account? &nbsp;&nbsp;<a href="/user/singup">Register here</a></p>  
               </div>
            </form>
        </div>
    </div>